<odoo>
    <!-- Order Form -->
    <record id="view_nst_order_form" model="ir.ui.view">
        <field name="name">nst.order.form</field>
        <field name="model">nst.order</field>
        <field name="arch" type="xml">
            <form string="NST Order">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="state"/>
                        <field name="currency_id"/>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="order_line_ids">
                                <list editable="bottom">
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="extra_cost"/>
                                    <field name="base_subtotal" readonly="1"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="quantity"/>
                                        <field name="price_unit"/>
                                        <field name="extra_cost"/>
                                        <field name="base_subtotal" readonly="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Order Tree -->
    <record id="view_nst_order_tree" model="ir.ui.view">
        <field name="name">nst.order.tree</field>
        <field name="model">nst.order</field>
        <field name="arch" type="xml">
            <list string="NST Orders">
                <field name="name"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_nst_order" model="ir.actions.act_window">
        <field name="name">NST Orders</field>
        <field name="res_model">nst.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_nst_root" name="NST Demo"/>
    <menuitem id="menu_nst_order" name="Orders" parent="menu_nst_root" action="action_nst_order"/>
</odoo>

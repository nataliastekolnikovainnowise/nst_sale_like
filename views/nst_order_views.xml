<odoo>
    <!-- Action -->
    <record id="action_nst_orders" model="ir.actions.act_window">
        <field name="name">NST Orders</field>
        <field name="res_model">nst.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Меню -->
    <menuitem id="menu_nst_order_root" name="NST Orders"/>
    <menuitem id="menu_nst_order" name="Orders"
              parent="menu_nst_order_root" action="action_nst_orders"/>

    <!-- List View -->
    <record id="view_nst_order_list" model="ir.ui.view">
        <field name="name">nst.order.list</field>
        <field name="model">nst.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="state"/>
                <field name="amount_total"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_nst_order_form" model="ir.ui.view">
        <field name="name">nst.order.form</field>
        <field name="model">nst.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary"
                            invisible="state == 'confirmed'"/>
                    <button name="action_set_draft" type="object" string="Set to Draft"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="customer_id"/>
                    </group>

                    <notebook>
                        <page string="Order Lines">
                            <field name="order_line_ids" mode="list,form" options="{'no_create': False}">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal" readonly="1"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="price_unit"/>
                                        <field name="subtotal" readonly="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <!-- NEW: Summary tab -->
                        <page string="Summary">
                            <group>
                                <field name="amount_total" readonly="1"/>
                                <field name="amount_avg" readonly="1"/>
                                <field name="amount_max" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>

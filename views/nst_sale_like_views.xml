<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ДЕЙСТВИЕ: список заказов -->
    <record id="action_nst_order" model="ir.actions.act_window">
        <field name="name">NST Orders</field>
        <field name="res_model">nst.order</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first NST Order
            </p>
        </field>
    </record>

    <!-- МЕНЮ: корень и пункт "Orders" -->
    <menuitem id="menu_nst_root" name="NST Demo" sequence="10"/>
    <menuitem id="menu_nst_order" name="Orders"
              parent="menu_nst_root"
              action="action_nst_order"
              sequence="10"/>

    <!-- LIST-вью для заказов (в 18 версии это <list>) -->
    <record id="view_nst_order_list" model="ir.ui.view">
        <field name="name">nst.order.list</field>
        <field name="model">nst.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- FORM-вью для заказов -->
    <record id="view_nst_order_form" model="ir.ui.view">
        <field name="name">nst.order.form</field>
        <field name="model">nst.order</field>
        <field name="arch" type="xml">
            <form string="NST Order">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ДЕЙСТВИЕ: список линий (удобно для отладки на Шаге 1) -->
    <record id="action_nst_order_line" model="ir.actions.act_window">
        <field name="name">NST Order Lines</field>
        <field name="res_model">nst.order.line</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- МЕНЮ: пункт "Order Lines" под корнем -->
    <menuitem id="menu_nst_order_line"
              name="Order Lines"
              parent="menu_nst_root"
              action="action_nst_order_line"
              sequence="20"/>

    <!-- LIST-вью для линий -->
    <record id="view_nst_order_line_list" model="ir.ui.view">
        <field name="name">nst.order.line.list</field>
        <field name="model">nst.order.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- FORM-вью для линий -->
    <record id="view_nst_order_line_form" model="ir.ui.view">
        <field name="name">nst.order.line.form</field>
        <field name="model">nst.order.line</field>
        <field name="arch" type="xml">
            <form string="NST Order Line">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
